# Uploaded documents (ijazah, transkrip - sensitive)
/storage/app/documents/*
!/storage/app/documents/.gitkeep
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*

# Logs contain personal data from OCR
/storage/logs/*
!/storage/logs/.gitkeep
!/storage/logs/.gitignore

# Python OCR temp files (copies of sensitive documents)
/python-service/temp/*
!/python-service/temp/.gitkeep

# Database
*.sqlite
*.sqlite-journal

# AI agent instructions — don't expose
/.agents/

# Python
__pycache__/
*.pyc
*.pyo
